<Window
    x:Class="WinSwitch.FullscreenTransitionWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="WinSwitch Transition"
    AllowsTransparency="True"
    Background="Black"
    BorderThickness="0"
    ResizeMode="NoResize"
    ShowActivated="False"
    ShowInTaskbar="False"
    Topmost="True"
    WindowStartupLocation="Manual"
    WindowStyle="None">
    <Grid x:Name="RootGrid" ClipToBounds="True" Background="Black">
        <Canvas x:Name="ImageCanvas">
            <Canvas.RenderTransform>
                <TranslateTransform x:Name="SlideTransform" />
            </Canvas.RenderTransform>

            <Image x:Name="CurrentImage" Stretch="Fill" />
            <Image x:Name="TargetImage" Stretch="Fill" />
        </Canvas>
    </Grid>
</Window>
