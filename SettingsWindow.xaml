<Window
    x:Class="WinSwitch.SettingsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="WinSwitch Settings - Created by Agraja"
    Width="520"
    Height="520"
    Background="#FFF7F4ED"
    ResizeMode="NoResize"
    WindowStartupLocation="CenterScreen">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel>
                <TextBlock FontFamily="Segoe UI Variable Display" FontSize="28" FontWeight="Bold" Foreground="#201A14" Text="WinSwitch" />
                <TextBlock Margin="0,6,0,0" FontSize="14" Foreground="#63584D" Text="Created by Agraja" />
            </StackPanel>

            <Border Grid.Row="1" Margin="0,22,0,0" Padding="18" Background="White" CornerRadius="18">
                <StackPanel>
                    <TextBlock FontSize="16" FontWeight="SemiBold" Text="Input methods" />
                    <CheckBox x:Name="AltTabCheckBox" Margin="0,14,0,0" Content="Use Ctrl+Alt+Left/Right keyboard shortcuts" />
                    <CheckBox x:Name="TouchpadSwipeCheckBox" Margin="0,10,0,0" Content="Use mapped three-finger touchpad swipes on the same shortcuts" />
                </StackPanel>
            </Border>

            <Border Grid.Row="2" Margin="0,18,0,0" Padding="18" Background="White" CornerRadius="18">
                <StackPanel>
                    <TextBlock FontSize="16" FontWeight="SemiBold" Text="Fullscreen swipe effect" />
                    <CheckBox x:Name="RequireFullscreenCheckBox" Margin="0,14,0,0" Content="Only animate when both apps are fullscreen-like" />
                    <TextBlock Margin="0,12,0,0" Foreground="#63584D" TextWrapping="Wrap"
                               Text="When enabled, WinSwitch animates only if both source and target windows cover the full display, similar to macOS fullscreen app swipes." />
                </StackPanel>
            </Border>

            <Border Grid.Row="3" Margin="0,18,0,0" Padding="18" Background="White" CornerRadius="18">
                <StackPanel>
                    <TextBlock FontSize="16" FontWeight="SemiBold" Text="Commit delay" />
                    <TextBlock x:Name="CommitDelayValueText" Margin="0,10,0,0" Foreground="#63584D" />
                    <Slider x:Name="CommitDelaySlider" Minimum="80" Maximum="700" TickFrequency="20" IsSnapToTickEnabled="True" />
                </StackPanel>
            </Border>

            <Border Grid.Row="4" Margin="0,18,0,0" Padding="18" Background="White" CornerRadius="18">
                <StackPanel>
                    <TextBlock FontSize="16" FontWeight="SemiBold" Text="Animation duration" />
                    <TextBlock x:Name="AnimationDurationValueText" Margin="0,10,0,0" Foreground="#63584D" />
                    <Slider x:Name="AnimationDurationSlider" Minimum="120" Maximum="600" TickFrequency="20" IsSnapToTickEnabled="True" />
                </StackPanel>
            </Border>

            <Border Grid.Row="5" Margin="0,18,0,0" Padding="18" Background="White" CornerRadius="18">
                <StackPanel>
                    <TextBlock FontSize="16" FontWeight="SemiBold" Text="Updates" />
                    <CheckBox x:Name="CheckForUpdatesCheckBox" Margin="0,14,0,0" Content="Check GitHub Releases on launch" />
                    <Button x:Name="CheckForUpdatesButton" Width="170" Height="36" Margin="0,14,0,0" HorizontalAlignment="Left" Content="Check for Updates Now" />
                </StackPanel>
            </Border>

            <Border Grid.Row="6" Margin="0,18,0,0" Padding="18" Background="#FFF1E2C7" CornerRadius="18">
                <TextBlock Foreground="#5E4220" TextWrapping="Wrap"
                           Text="Touchpad tip: in Windows Settings > Bluetooth &amp; devices > Touchpad > Advanced gestures, map three-finger left/right to Ctrl+Alt+Left and Ctrl+Alt+Right." />
            </Border>

            <DockPanel Grid.Row="7" Margin="0,22,0,0" LastChildFill="False">
                <TextBlock VerticalAlignment="Center" Foreground="#63584D" Text="Version 1.0.08 - Created by Agraja" />
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                    <Button x:Name="OpenSettingsFileButton" Width="130" Height="38" Margin="0,0,10,0" Content="Open Settings File" />
                    <Button x:Name="SaveButton" Width="96" Height="38" Content="Save" />
                </StackPanel>
            </DockPanel>
        </Grid>
    </ScrollViewer>
</Window>
