<Window
    x:Class="WinSwitch.SwitcherOverlayWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="WinSwitch"
    Width="900"
    Height="220"
    AllowsTransparency="True"
    Background="Transparent"
    BorderThickness="0"
    ResizeMode="NoResize"
    ShowActivated="False"
    ShowInTaskbar="False"
    Topmost="True"
    WindowStartupLocation="CenterScreen"
    WindowStyle="None">
    <Grid>
        <Border
            Padding="26"
            Background="#F2222228"
            BorderBrush="#59FFFFFF"
            BorderThickness="1"
            CornerRadius="26"
            SnapsToDevicePixels="True">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock
                    Margin="0,0,0,16"
                    FontFamily="Segoe UI Variable Display"
                    FontSize="18"
                    FontWeight="SemiBold"
                    Foreground="#F8F8F8"
                    Text="App Switcher" />

                <ScrollViewer
                    Grid.Row="1"
                    HorizontalScrollBarVisibility="Hidden"
                    VerticalScrollBarVisibility="Disabled">
                    <ItemsControl x:Name="AppItemsControl">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border
                                    Width="150"
                                    Margin="0,0,14,0"
                                    Padding="16"
                                    Background="{Binding CardBackground}"
                                    BorderBrush="{Binding CardBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="22">
                                    <StackPanel>
                                        <Border
                                            Width="58"
                                            Height="58"
                                            Margin="0,0,0,14"
                                            Background="#14FFFFFF"
                                            CornerRadius="16">
                                            <Image
                                                Width="42"
                                                Height="42"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                Source="{Binding Icon}" />
                                        </Border>

                                        <TextBlock
                                            FontFamily="Segoe UI Variable Display"
                                            FontSize="15"
                                            FontWeight="SemiBold"
                                            Foreground="#FFFFFF"
                                            Text="{Binding DisplayName}"
                                            TextTrimming="CharacterEllipsis" />

                                        <TextBlock
                                            Margin="0,4,0,0"
                                            FontFamily="Segoe UI Variable Text"
                                            FontSize="12"
                                            Foreground="#C9D0D8"
                                            Text="{Binding Subtitle}"
                                            TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</Window>
