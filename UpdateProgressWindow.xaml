<Window
    x:Class="WinSwitch.UpdateProgressWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="WinSwitch Update"
    Width="420"
    Height="180"
    ResizeMode="NoResize"
    WindowStartupLocation="CenterScreen"
    WindowStyle="ToolWindow"
    ShowInTaskbar="False"
    Topmost="True">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock x:Name="TitleTextBlock" FontSize="22" FontWeight="SemiBold" Foreground="#201A14" Text="Updating WinSwitch" />
        <TextBlock x:Name="StatusTextBlock" Grid.Row="1" Margin="0,10,0,0" Foreground="#5F584F" TextWrapping="Wrap" Text="Preparing update..." />
        <ProgressBar x:Name="ProgressBar" Grid.Row="2" Margin="0,20,0,0" Height="16" Minimum="0" Maximum="100" />
    </Grid>
</Window>
